# Copie ce fichier en .env (jamais committé) et remplis les valeurs.
# En production (Render), ces variables se déclarent dans le dashboard,
# PAS dans un fichier.

# Token Bearer qui protège POST /recrue. Mets une valeur longue et aléatoire.
API_TOKEN=ligue-des-heros-2026

# Mode debug : false en production (true seulement en local si besoin).
FLASK_DEBUG=false

# Port d'écoute. En local, défaut 5004. En prod, Render impose PORT lui-même.
PORT=5004
