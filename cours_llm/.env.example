# ============================================================
# Configuration du LLM — copie ce fichier en ".env" et remplis-le
#   cp .env.example .env
# ============================================================
# Le code parle au LLM via l'interface compatible OpenAI. Anthropic (Claude)
# expose aussi cette interface : on l'utilise par défaut ci-dessous. Pour
# changer de fournisseur, il suffit de modifier ce fichier — pas le code.

# --- CHAT (démos 1 à 5) : Anthropic / Claude ---
LLM_BASE_URL=https://api.anthropic.com/v1/
LLM_API_KEY=sk-ant-remplace-par-ta-cle
LLM_MODEL=claude-sonnet-4-6

# --- EMBEDDINGS (démo 6 uniquement) ---
# ⚠️ Anthropic ne fournit PAS d'API d'embeddings. Pour la démo 6, on passe
#    par un autre fournisseur via les variables EMBED_*. Laisse-les vides
#    pour réutiliser le bloc CHAT (utile uniquement avec Ollama).
# Exemple Voyage AI (l'embeddings recommandé par Anthropic) :
EMBED_BASE_URL=https://api.voyageai.com/v1
EMBED_API_KEY=pa-remplace-par-ta-cle
LLM_EMBED_MODEL=voyage-3
# Exemple OpenAI (décommente et adapte) :
#   EMBED_BASE_URL=https://api.openai.com/v1
#   EMBED_API_KEY=sk-...
#   LLM_EMBED_MODEL=text-embedding-3-small

# --- Alternative : tout en local avec Ollama (gratuit, sans clé) ---
# Installe Ollama (https://ollama.com), puis :
#   ollama pull llama3.2  &&  ollama pull nomic-embed-text
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2
# EMBED_BASE_URL=http://localhost:11434/v1
# EMBED_API_KEY=ollama
# LLM_EMBED_MODEL=nomic-embed-text