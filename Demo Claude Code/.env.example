# ============================================================
# .env.example — Configuration de la démo
# ============================================================
# Copie ce fichier en .env et renseigne les valeurs.
#   cp .env.example .env
#
# NB : la démo lit AUSSI automatiquement les .env de cours_llm/,
# cours_agents_llm/ et de la racine du repo. Si la config LLM y est
# déjà présente, tu n'as rien à remplir ici (sauf override).
# ============================================================

# --- Serveur Flask ---
FLASK_DEBUG=true
PORT=5000

# --- Authentification des endpoints protégés (Bearer) ---
# Le préfixe "Bearer " est optionnel (l'app le tolère des deux côtés).
API_TOKEN=dev-token-change-me

# --- LLM (interface compatible OpenAI ; cible Anthropic par défaut) ---
LLM_BASE_URL=https://api.anthropic.com/v1/
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6

# --- Embeddings (cours LLM, démo /api/llm/embeddings) ---
# ⚠️ Anthropic ne fournit PAS d'embeddings. Pour activer cette démo,
# configure un fournisseur dédié (Voyage AI, OpenAI, ou Ollama local).
# Sans cela, l'endpoint renvoie un 503 explicite (le reste fonctionne).
# Exemple Voyage AI :
#   EMBED_BASE_URL=https://api.voyageai.com/v1
#   EMBED_API_KEY=pa-...
#   LLM_EMBED_MODEL=voyage-3

# --- Agents : webhook n8n optionnel ---
# N8N_WEBHOOK_URL=
